# .env — Développement local
# Copier ce fichier à la racine du projet : cp .env.dev .env

# ── Core ──────────────────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=django-insecure-9etyf7ixl()t7p0au1!9m%=vvc-%hx43=lvssg-!q4q^7*vx^8
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost,flexible-lemur-strangely.ngrok-free.app,e7e9-41-85-163-159.ngrok-free.app

# ── Base de données ───────────────────────────────────────────────────────────
# SQLite + SpatiaLite (zéro config)
# Prérequis : sudo apt install spatialite-bin libsqlite3-mod-spatialite
USE_POSTGIS=False

# ── Cache ─────────────────────────────────────────────────────────────────────
USE_REDIS_CACHE=False

# ── Redis (Celery broker) ─────────────────────────────────────────────────────
# Lancer Redis via Docker : docker run -d -p 6379:6379 redis:7-alpine
REDIS_URL=redis://127.0.0.1:6379/0

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ALLOW_ALL_ORIGINS=True

# ── HTTPS ─────────────────────────────────────────────────────────────────────
USE_HTTPS=False

# ── Email ─────────────────────────────────────────────────────────────────────
# Affiché dans le terminal en dev — pas besoin de SendGrid
DEFAULT_FROM_EMAIL=noreply@pharmalink.bj

# ── Outils de développement ───────────────────────────────────────────────────
USE_DEBUG_TOOLBAR=True
USE_DJANGO_EXTENSIONS=True

# ── Sentry ────────────────────────────────────────────────────────────────────
# Laisser vide en dev pour désactiver Sentry
SENTRY_DSN=""

# ── Version ───────────────────────────────────────────────────────────────────
APP_VERSION=1.0.0-dev

EXPO_PUBLIC_API_URL=https://flexible-lemur-strangely.ngrok-free.app/api/v1
